{
  "__inputs": [
    {
      "name": "DS_METRICS",
      "label": "Metrics (Mimir/Prometheus)",
      "description": "Grafana Cloud Mimir または Prometheus データソース",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "title": "Claude Code 集計・レポート",
  "uid": "claude-code-summary",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1h",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "user",
        "label": "ユーザー",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_METRICS}"
        },
        "query": "label_values(claude_code_cost_usage_USD_total, user_email)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "過去24時間 コスト合計 (USD)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "コスト (過去24時間)"
        }
      ]
    },
    {
      "id": 2,
      "title": "過去24時間 トークン消費量",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "トークン (過去24時間)"
        }
      ]
    },
    {
      "id": 3,
      "title": "過去24時間 セッション数",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_session_count_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "セッション数 (過去24時間)"
        }
      ]
    },
    {
      "id": 4,
      "title": "過去24時間 コード変更行数",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "コード変更行数 (過去24時間)"
        }
      ]
    },
    {
      "id": 7,
      "title": "モデル別コスト内訳 (過去24時間)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      },
      "options": {
        "pieType": "pie",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{model}}",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "トークン種別内訳 (過去24時間)",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "options": {
        "pieType": "pie",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{type}}",
          "instant": true
        }
      ]
    },
    {
      "id": 40,
      "title": "ユーザー別トークン Top 10 (過去24時間)",
      "type": "barchart",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "xTickLabelRotation": -45,
        "barWidth": 0.7,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (user_email) (increase(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[24h])))",
          "legendFormat": "{{user_email}}",
          "instant": true
        }
      ]
    },
    {
      "id": 50,
      "title": "日別トレンド",
      "type": "row",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 51,
      "title": "日別トークン消費量 (過去30日)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars",
            "barAlignment": 0
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[1d]))",
          "legendFormat": "{{user_email}}",
          "step": "1d"
        }
      ]
    },
    {
      "id": 52,
      "title": "日別コスト推移 (過去30日)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars",
            "barAlignment": 0
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[1d]))",
          "legendFormat": "{{user_email}}",
          "step": "1d"
        }
      ]
    },
    {
      "id": 53,
      "title": "時間帯別使用パターン (過去7日)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[1h])) * 3600",
          "legendFormat": "トークン消費 (トークン/時間)"
        },
        {
          "expr": "sum(rate(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[1h])) * 3600 * 1000",
          "legendFormat": "コスト (mUSD/時間)"
        }
      ]
    },
    {
      "id": 60,
      "title": "ユーザー別集計",
      "type": "row",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "ユーザー別コスト (過去24時間)",
      "type": "table",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 4 },
        "overrides": []
      },
      "options": { "sortBy": [{ "desc": true, "displayName": "コスト (USD)" }] },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{user_email}}",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "user_email": "ユーザー",
              "Value": "コスト (USD)",
              "Value #A": "コスト (USD)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "desc": true, "displayName": "コスト (USD)" }]
          }
        }
      ]
    },
    {
      "id": 22,
      "title": "ユーザー別トークン消費量 (過去24時間)",
      "type": "table",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "sortBy": [] },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{user_email}}",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "user_email": "ユーザー",
              "Value": "トークン消費量",
              "Value #A": "トークン消費量"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "desc": true, "displayName": "トークン消費量" }]
          }
        }
      ]
    },
    {
      "id": 23,
      "title": "ユーザー別セッション数 (過去24時間)",
      "type": "table",
      "gridPos": { "x": 0, "y": 38, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "sortBy": [] },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_session_count_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{user_email}}",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "user_email": "ユーザー",
              "Value": "セッション数",
              "Value #A": "セッション数"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "desc": true, "displayName": "セッション数" }]
          }
        }
      ]
    },
    {
      "id": 26,
      "title": "ユーザー別コード変更行数 (過去24時間)",
      "type": "table",
      "gridPos": { "x": 12, "y": 38, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "sortBy": [] },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_lines_of_code_count_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{user_email}}",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "user_email": "ユーザー",
              "Value": "コード変更行数",
              "Value #A": "コード変更行数"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "desc": true, "displayName": "コード変更行数" }]
          }
        }
      ]
    },
    {
      "id": 27,
      "title": "ターミナル種別 × ユーザー (過去24時間)",
      "type": "table",
      "gridPos": { "x": 0, "y": 46, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_METRICS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "sortBy": [] },
      "targets": [
        {
          "expr": "sum by (user_email, terminal_type) (increase(claude_code_session_count_total{user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{user_email}} / {{terminal_type}}",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "user_email": "ユーザー",
              "terminal_type": "ターミナル種別",
              "Value": "セッション数",
              "Value #A": "セッション数"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "desc": true, "displayName": "セッション数" }]
          }
        }
      ]
    }
  ]
}
