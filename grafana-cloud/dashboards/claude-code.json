      "id": 21,
      "title": "ユーザー別コスト (USD)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "sortBy": []
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[$__range]))",
          "legendFormat": "{{user_email}}",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "renameByName": {
              "user_email": "ユーザー",
              "terminal_type": "ターミナル",
              "Value": "コスト (USD)",
              "Value #A": "コスト (USD)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "desc": true,
                "displayName": "コスト (USD)"
              }
            ]
          }
        }
      ]
    },
