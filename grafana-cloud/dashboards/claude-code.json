{
  "__inputs": [
    {
      "name": "DS_METRICS",
      "label": "Metrics (Mimir/Prometheus)",
      "description": "Grafana Cloud Mimir または Prometheus データソース",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "title": "Claude Code 監視",
  "uid": "claude-code-monitoring",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "user",
        "label": "ユーザー",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_METRICS}"
        },
        "query": "label_values(claude_code_cost_usage_USD_total, user_email)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "コスト累計 (USD)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "unit": "currencyUSD"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[$__range]))",
          "legendFormat": "累計コスト"
        }
      ]
    },
    {
      "id": 2,
      "title": "トークン消費量 累計",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[$__range]))",
          "legendFormat": "累計トークン"
        }
      ]
    },
    {
      "id": 3,
      "title": "セッション数 累計",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(last_over_time(claude_code_session_count_total{user_email=~\"$user\"}[$__range]))",
          "legendFormat": "セッション数"
        }
      ]
    },
    {
      "id": 4,
      "title": "コード変更行数 累計",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total{user_email=~\"$user\"}[$__range]))",
          "legendFormat": "変更行数"
        }
      ]
    },
    {
      "id": 5,
      "title": "コスト推移（1時間ごと）",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[1h]))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "トークン消費量（1時間ごと）",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total{user_email=~\"$user\"}[1h]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "モデル別コスト内訳",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "options": {
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[$__range]))",
          "legendFormat": "{{model}}"
        }
