        "y": 12,
        "w": 16,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_METRICS}"
      },
      "targets": [
        {
          "expr": "count(last_over_time(claude_code_session_count_total{user_email=~\"$user\"}[1d]))",
