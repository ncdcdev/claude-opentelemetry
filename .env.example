# OTel Collector の Basic 認証は otel.htpasswd ファイル（.gitignore 済み）で渡す。
# .env の変数では bcrypt の $ が Docker Compose に壊されやすいため使わない。
# 生成例（リポジトリ直下に出力）:
#   docker run --rm httpd htpasswd -nbB claude 'your-password' > otel.htpasswd

# Grafana 管理者パスワード（初回ログイン用）
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# --- 会社展開時: Google Workspace OAuth（個人用は false のまま） ---
GF_AUTH_GOOGLE_ENABLED=false
GF_AUTH_GOOGLE_CLIENT_ID=
GF_AUTH_GOOGLE_CLIENT_SECRET=
GF_AUTH_GOOGLE_ALLOWED_DOMAINS=yourcompany.com
GF_AUTH_GOOGLE_ALLOW_SIGN_UP=true

# --- Grafana Cloud デプロイ設定 ---
# Grafana Cloud の URL（例: https://your-org.grafana.net）
GRAFANA_CLOUD_URL=

# Grafana Cloud の Service Account Token
# 権限: Dashboards: Edit
GRAFANA_CLOUD_API_KEY=

# （オプション）Prometheus データソースの UID
GRAFANA_METRICS_DS_UID=

# （オプション）ダッシュボードに表示するメールドメインの制限
# 設定するとデプロイ時にクエリへ焼き込まれ、URL パラメータでもバイパス不可になる
# 例: yourcompany.com（@記号は不要）。空の場合は全ユーザーを表示
GRAFANA_ALLOWED_EMAIL_DOMAIN=
