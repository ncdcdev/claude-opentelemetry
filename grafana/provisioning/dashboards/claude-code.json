{
  "title": "Claude Code 監視",
  "uid": "claude-code-monitoring",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "user",
        "label": "ユーザー",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_cost_usage_USD_total, user_email)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "コスト累計 (USD)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "unit": "currencyUSD"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "累計コスト"
        }
      ]
    },
    {
      "id": 2,
      "title": "トークン消費量 累計",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "累計トークン"
        }
      ]
    },
    {
      "id": 3,
      "title": "セッション数 累計",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(count_over_time(claude_code_session_count_total{user_account_uuid=~\"$user\"}[$__range]) > 0)",
          "legendFormat": "セッション数"
        }
      ]
    },
    {
      "id": 4,
      "title": "コード変更行数 累計",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "変更行数"
        }
      ]
    },
    {
      "id": 5,
      "title": "コスト推移（1時間ごと）",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total{user_account_uuid=~\"$user\"}[1h]))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "トークン消費量（1時間ごと）",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total{user_account_uuid=~\"$user\"}[1h]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "モデル別コスト内訳",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "pieType": "donut" },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "セッション数（日別）",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(count_over_time(claude_code_session_count_total{user_account_uuid=~\"$user\"}[1d]) > 0)",
          "legendFormat": "セッション数/日"
        }
      ]
    },
    {
      "id": 9,
      "title": "コスト累計推移",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(claude_code_cost_usage_USD_total{user_account_uuid=~\"$user\"})",
          "legendFormat": "累計コスト"
        }
      ]
    },
    {
      "id": 10,
      "title": "トークン消費量 累計推移",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (type) (claude_code_token_usage_tokens_total{user_account_uuid=~\"$user\"})",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 20,
      "title": "ユーザー別分析",
      "type": "row",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "ユーザー別コスト (USD)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 29, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_cost_usage_USD_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "{{user_email}}"
        }
      ]
    },
    {
      "id": 22,
      "title": "ユーザー別トークン消費量",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 29, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100000 },
              { "color": "red", "value": 500000 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_token_usage_tokens_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "{{user_email}}"
        }
      ]
    },
    {
      "id": 23,
      "title": "ユーザー別セッション数",
      "type": "bargauge",
      "gridPos": { "x": 16, "y": 29, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_session_count_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "{{user_email}}"
        }
      ]
    },
    {
      "id": 24,
      "title": "ユーザー別コスト推移（1時間ごと）",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_cost_usage_USD_total{user_account_uuid=~\"$user\"}[1h]))",
          "legendFormat": "{{user_email}}"
        }
      ]
    },
    {
      "id": 25,
      "title": "ユーザー別トークン推移（1時間ごと）",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_token_usage_tokens_total{user_account_uuid=~\"$user\"}[1h]))",
          "legendFormat": "{{user_email}}"
        }
      ]
    },
    {
      "id": 26,
      "title": "ユーザー別コード変更行数",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 45, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_lines_of_code_count_total{user_account_uuid=~\"$user\"}[$__range]))",
          "legendFormat": "{{user_email}}"
        }
      ]
    },
    {
      "id": 27,
      "title": "ユーザー別アクティブ時間（分）",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 45, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (increase(claude_code_active_time_total_seconds_total{user_account_uuid=~\"$user\"}[$__range])) / 60",
          "legendFormat": "{{user_email}}"
        }
      ]
    }
  ]
}
